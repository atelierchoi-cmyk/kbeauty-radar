# App identity — used in headers, <title>, and metadata (see src/lib/config.ts)
NEXT_PUBLIC_APP_NAME="K-Beauty Radar"

# Public site URL — used to build sitemap.xml / robots.txt absolute URLs
NEXT_PUBLIC_SITE_URL="https://your-domain.example.com"

# Supabase — leave both unset to run in local-JSON demo-data mode
# (src/lib/config.ts USE_SUPABASE becomes false automatically).
# Set both to switch src/lib/data.ts over to live Supabase queries.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Server-only Supabase service role key — required only for admin
# write operations (see /admin) once wired to Supabase. NEVER expose
# this with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=""
